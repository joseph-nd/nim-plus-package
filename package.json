{
	"name": "nim-plus-package",
	"version": "0.1.1",
	"description": "Foundry VTT module that adds Nim+ content to the Nimble system.",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "node ./build/buildCompendia.mjs",
		"build:compendia": "node ./build/buildCompendia.mjs",
		"release": "node ./build/release.mjs",
		"clean": "rm -rf packs/nim-plus-* dist"
	},
	"engines": {
		"node": ">=22.1.0",
		"pnpm": ">=10.0.0"
	},
	"packageManager": "pnpm@10.11.0",
	"devDependencies": {
		"classic-level": "^1.4.1",
		"glob": "^11.0.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["classic-level"]
	}
}
